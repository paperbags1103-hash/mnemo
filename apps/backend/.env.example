# ── Database ────────────────────────────────────────────
# SQLite (local dev, default)
SQLITE_PATH=.data/mnemo.db

# Turso cloud DB (optional, recommended for production)
# TURSO_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Auth (optional) ─────────────────────────────────────
# Uncomment to require Bearer token for write operations
# MNEMO_TOKEN=your-secret-token

# ── lorien Knowledge Graph (optional) ───────────────────
# Only needed if you have lorien installed locally
# https://github.com/paperbags1103-hash/lorien
# LORIEN_DB_PATH=~/.lorien/db
# LORIEN_SRC_PATH=~/lorien/src

# ── CORS ────────────────────────────────────────────────
# Additional allowed origins (comma-separated), e.g. your deployed frontend URL
# CORS_ORIGINS=https://your-app.vercel.app
